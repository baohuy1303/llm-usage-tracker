@baseUrl = http://localhost:8080

### GET Health Check
GET {{baseUrl}}/healthz


### ----------------------------------------------------
### PROJECTS
### ----------------------------------------------------

### Create Project (all three budgets set)
POST {{baseUrl}}/projects/create
Content-Type: application/json

{
  "name": "Super AI Project",
  "daily_budget_dollars": 50.00,
  "monthly_budget_dollars": 1000.00,
  "total_budget_dollars": 10000.00
}

### Create Project with only daily budget (monthly/total nullable)
POST {{baseUrl}}/projects/create
Content-Type: application/json

{
  "name": "Daily Only Project",
  "daily_budget_dollars": 20.00
}

### Create Project with no budgets at all (all nullable)
POST {{baseUrl}}/projects/create
Content-Type: application/json

{
  "name": "Unlimited Project"
}

### Error - Create Project with duplicate name
POST {{baseUrl}}/projects/create
Content-Type: application/json

{
  "name": "Super AI Project",
  "daily_budget_dollars": 10.00
}

### Error - Create Project with empty name
POST {{baseUrl}}/projects/create
Content-Type: application/json

{
  "name": "",
  "daily_budget_dollars": 10.00
}

### Error - Create Project with invalid (negative) budget
POST {{baseUrl}}/projects/create
Content-Type: application/json

{
  "name": "Bad Budget Project",
  "daily_budget_dollars": -1.00
}

### List Projects
GET {{baseUrl}}/projects

### Get Project By ID
GET {{baseUrl}}/projects/1

### Error - Get Non-Existent Project
GET {{baseUrl}}/projects/9999

### Update Project - change daily budget only
PATCH {{baseUrl}}/projects/1
Content-Type: application/json

{
  "daily_budget_dollars": 75.00
}

### Update Project - set all three budgets
PATCH {{baseUrl}}/projects/1
Content-Type: application/json

{
  "daily_budget_dollars": 100.00,
  "monthly_budget_dollars": 2000.00,
  "total_budget_dollars": 20000.00
}

### Update Project - rename + update monthly budget
PATCH {{baseUrl}}/projects/1
Content-Type: application/json

{
  "name": "Mega AI Project",
  "monthly_budget_dollars": 1500.00
}

### Delete Project
DELETE {{baseUrl}}/projects/1

### Error - Get Deleted Project
GET {{baseUrl}}/projects/1


### ----------------------------------------------------
### MODELS
### ----------------------------------------------------

### List Models
GET {{baseUrl}}/models

### Create Model
POST {{baseUrl}}/models
Content-Type: application/json

{
  "name": "custom-model-x",
  "input_per_million_cents": 50,
  "output_per_million_cents": 200
}

### Error - Create Model with duplicate name
POST {{baseUrl}}/models
Content-Type: application/json

{
  "name": "custom-model-x",
  "input_per_million_cents": 50,
  "output_per_million_cents": 200
}

### Error - Create Model with negative pricing
POST {{baseUrl}}/models
Content-Type: application/json

{
  "name": "bad-price-model",
  "input_per_million_cents": -10,
  "output_per_million_cents": 200
}

### Get Model By ID
GET {{baseUrl}}/models/1

### Error - Get Non-Existent Model
GET {{baseUrl}}/models/9999

### Update Model (Partial - output pricing only)
PATCH {{baseUrl}}/models/10
Content-Type: application/json

{
  "output_per_million_cents": 250
}

### Delete Model
DELETE {{baseUrl}}/models/10


### ----------------------------------------------------
### USAGE
### ----------------------------------------------------

### Add Usage (cost_cents is computed server-side from model pricing)
POST {{baseUrl}}/projects/1/usage
Content-Type: application/json

{
  "model": "claude-sonnet-4-20250514",
  "tokens_in": 1000,
  "tokens_out": 500,
  "latency_ms": 1200,
  "tag": "chat"
}

### Add Usage - asymmetric tokens (verify daily stats shows tokens_in/out split)
### Post this, then GET /projects/1/usage/daily — response should show
### tokens_in=5000, tokens_out=200, tokens=5200 distinctly.
POST {{baseUrl}}/projects/1/usage
Content-Type: application/json

{
  "model": "gpt-4o-mini",
  "tokens_in": 5000,
  "tokens_out": 200,
  "latency_ms": 300,
  "tag": "summarize"
}

### Get Daily Stats - today (reads from Redis cache if warm)
GET {{baseUrl}}/projects/1/usage/daily

### Add Usage - latency_ms omitted (now nullable; field absent from response)
POST {{baseUrl}}/projects/1/usage
Content-Type: application/json

{
  "model": "gpt-4o-mini",
  "tokens_in": 100,
  "tokens_out": 50,
  "tag": "untimed"
}

### Add Usage - second event same day (Redis INCRBY should accumulate)
POST {{baseUrl}}/projects/1/usage
Content-Type: application/json

{
  "model": "gpt-4o",
  "tokens_in": 2000,
  "tokens_out": 800,
  "latency_ms": 950,
  "tag": "summary"
}

### Add Usage - different tag
POST {{baseUrl}}/projects/1/usage
Content-Type: application/json

{
  "model": "gemini-2.5-flash",
  "tokens_in": 500,
  "tokens_out": 200,
  "latency_ms": 400,
  "tag": "embedding"
}

### Push daily spend OVER budget — response should show over_budget=true
### (budget on project 1 is 5000 cents; 1M input tokens on claude-opus-4 ≈ 1500 cents per call)
POST {{baseUrl}}/projects/1/usage
Content-Type: application/json

{
  "model": "claude-opus-4-20250514",
  "tokens_in": 1000000,
  "tokens_out": 500000,
  "latency_ms": 3000,
  "tag": "bulk"
}

### Fire the same bulk call again to push total over multiple budgets
POST {{baseUrl}}/projects/1/usage
Content-Type: application/json

{
  "model": "claude-opus-4-20250514",
  "tokens_in": 1000000,
  "tokens_out": 500000,
  "latency_ms": 3000,
  "tag": "bulk"
}

### GET project — should now show budget_status with over_budget flags
GET {{baseUrl}}/projects/1

### Error - Add Usage with unknown model
POST {{baseUrl}}/projects/1/usage
Content-Type: application/json

{
  "model": "not-a-real-model",
  "tokens_in": 100,
  "tokens_out": 50,
  "latency_ms": 200,
  "tag": "test"
}

### Error - Add Usage to non-existent project
POST {{baseUrl}}/projects/9999/usage
Content-Type: application/json

{
  "model": "gpt-4o-mini",
  "tokens_in": 100,
  "tokens_out": 50,
  "latency_ms": 200,
  "tag": "test"
}

### Error - Add Usage with invalid project ID
POST {{baseUrl}}/projects/abc/usage
Content-Type: application/json

{
  "model": "gpt-4o-mini",
  "tokens_in": 100,
  "tokens_out": 50,
  "latency_ms": 200,
  "tag": "test"
}

### ----------------------------------------------------
### USAGE STATS (Redis cache → SQL fallback)
### ----------------------------------------------------

### Get Daily Stats - today (reads from Redis cache if warm)
GET {{baseUrl}}/projects/1/usage/daily

### Get Daily Stats - specific date
GET {{baseUrl}}/projects/1/usage/daily?date=2026-04-21

### Error - Get Daily Stats with invalid date format
GET {{baseUrl}}/projects/1/usage/daily?date=21-04-2026

### Get Monthly Stats - current month (reads from Redis cache if warm)
GET {{baseUrl}}/projects/1/usage/monthly

### Get Monthly Stats - specific month
GET {{baseUrl}}/projects/1/usage/monthly?month=2026-04

### Error - Get Monthly Stats with invalid month format
GET {{baseUrl}}/projects/1/usage/monthly?month=2026/04

### Get Stats for project with no usage (should return zeros)
GET {{baseUrl}}/projects/2/usage/daily

### Get Stats for non-existent project (returns zeros, not an error)
GET {{baseUrl}}/projects/9999/usage/daily


### ----------------------------------------------------
### USAGE RANGE & SUMMARY (SQL-only, no cache)
### ----------------------------------------------------

### Project Range - single project, arbitrary date window
GET {{baseUrl}}/projects/1/usage/range?from=2026-04-01&to=2026-04-21

### Project Range - same from/to (equivalent to daily stats)
GET {{baseUrl}}/projects/1/usage/range?from=2026-04-21&to=2026-04-21

### Project Range - no usage in window (returns zeros)
GET {{baseUrl}}/projects/1/usage/range?from=2020-01-01&to=2020-01-31

### Project Range - non-existent project (returns zeros, not an error)
GET {{baseUrl}}/projects/9999/usage/range?from=2026-04-01&to=2026-04-21

### Error - Project Range missing from
GET {{baseUrl}}/projects/1/usage/range?to=2026-04-21

### Error - Project Range missing to
GET {{baseUrl}}/projects/1/usage/range?from=2026-04-01

### Error - Project Range with from > to
GET {{baseUrl}}/projects/1/usage/range?from=2026-04-21&to=2026-04-01

### Error - Project Range with invalid date format
GET {{baseUrl}}/projects/1/usage/range?from=04-01-2026&to=04-21-2026

### Project Range - RFC3339 timestamps (exact window, e.g. a 4-hour slice)
GET {{baseUrl}}/projects/1/usage/range?from=2026-04-21T10:00:00Z&to=2026-04-21T14:00:00Z

### Project Range - mixed date + timestamp (from=start of day, to=exact)
GET {{baseUrl}}/projects/1/usage/range?from=2026-04-21&to=2026-04-21T12:00:00Z


### Usage Summary - all projects with per-project breakdown + totals
GET {{baseUrl}}/usage/summary?from=2026-04-01&to=2026-04-21

### Usage Summary - RFC3339 timestamps (exact window)
GET {{baseUrl}}/usage/summary?from=2026-04-21T00:00:00Z&to=2026-04-21T12:00:00Z

### Usage Summary - single day
GET {{baseUrl}}/usage/summary?from=2026-04-21&to=2026-04-21

### Usage Summary - empty window (no usage → empty projects array, zero totals)
GET {{baseUrl}}/usage/summary?from=2020-01-01&to=2020-01-31

### Error - Usage Summary missing both params
GET {{baseUrl}}/usage/summary

### Error - Usage Summary with from > to
GET {{baseUrl}}/usage/summary?from=2026-04-21&to=2026-04-01

### Error - Usage Summary with invalid date
GET {{baseUrl}}/usage/summary?from=not-a-date&to=2026-04-21


### ----------------------------------------------------
### USAGE EVENTS (cursor-paginated lists of raw events)
### ----------------------------------------------------

### Project events - first page, all-time (30 per page default)
GET {{baseUrl}}/projects/1/usage/events

### Project events - explicit date range + smaller page
GET {{baseUrl}}/projects/1/usage/events?from=2026-04-01&to=2026-04-30&limit=10

### Project events - next page (paste next_cursor value from previous response)
GET {{baseUrl}}/projects/1/usage/events?cursor=<paste-here>

### All projects - first page, all-time
GET {{baseUrl}}/usage/events

### All projects - scoped to today with small page
GET {{baseUrl}}/usage/events?from=2026-04-21&to=2026-04-21&limit=5

### All projects - next page
GET {{baseUrl}}/usage/events?cursor=<paste-here>

### Events - limit boundary clamping (request 500, gets capped at 100 per server policy)
GET {{baseUrl}}/usage/events?limit=500

### Error - invalid cursor
GET {{baseUrl}}/usage/events?cursor=not-a-real-cursor

### Error - invalid limit
GET {{baseUrl}}/usage/events?limit=abc

### Error - from > to
GET {{baseUrl}}/usage/events?from=2026-04-21&to=2026-04-01
