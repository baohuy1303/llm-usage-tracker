    {
      "id": 5,
      "type": "stat",
      "title": "Daily Budget Used (%)",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
