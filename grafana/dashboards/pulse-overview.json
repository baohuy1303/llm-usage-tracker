    {
      "id": 8,
      "type": "table",
      "title": "Latest 5 Calls",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "pulse-api" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "pulse-api" },
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "/projects/${project}/usage/events",
          "url_options": {
            "method": "GET",
            "data": "",
            "params": [
              { "key": "limit", "value": "5" }
            ]
          },
          "root_selector": "events",
          "columns": [
            { "selector": "created_at",  "text": "Time",         "type": "timestamp" },
            { "selector": "model",       "text": "Model",        "type": "string" },
            { "selector": "tokens_in",   "text": "Tokens In",    "type": "number" },
            { "selector": "tokens_out",  "text": "Tokens Out",   "type": "number" },
            { "selector": "cost_dollars","text": "Cost",         "type": "number" },
            { "selector": "latency_ms",  "text": "Latency (ms)", "type": "number" }
          ],
          "filters": []
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "displayMode": "auto" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Latency (ms)" },
            "properties": [
              { "id": "unit", "value": "ms" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 1000 },
                    { "color": "red", "value": 2000 }
                  ]
                }
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Cost" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "decimals", "value": 5 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 0.10 }
                  ]
                }
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
